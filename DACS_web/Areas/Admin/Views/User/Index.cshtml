@model IEnumerable<DACS_web.Models.ApplicationUser>
@{
    ViewData["Title"] = "Danh sách người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="users-container">
    <div class="search-container mb-4">
        <form asp-action="Index" method="get" class="search-form">
            <div class="input-group">
                <input type="text" name="searchEmail" class="form-control" placeholder="Tìm kiếm theo email..." value="@ViewBag.CurrentFilter">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i> Tìm kiếm
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-redo"></i> Làm mới
                </a>
            </div>
        </form>
    </div>
    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Họ tên</th>
                            <th>Vai trò</th>
                            <th>Mã bệnh nhân</th>
                            <th>Mã Nhân viên</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Email</td>
                                <td>@user.FullName</td>
                                <td>
                                    <span class="badge bg-info text-dark">@ViewBag.UserRoles[user.Id]</span>
                                </td>
                                <td>@user.MaBenhNhan</td>
                                <td>@user.MaNhanVien</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash-alt"></i> Xoá
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/user-list.css" />