@model DACS_web.Models.CaTruc
@{
    ViewData["Title"] = "Thêm ca trực";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>@ViewData["Title"]</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MaNhanVien" class="form-label">
                            <i class="fas fa-user me-1"></i>Nhân viên
                        </label>
                        <select asp-for="MaNhanVien" class="form-select" asp-items="ViewBag.MaNhanVien">
                            <option value="">-- Chọn nhân viên --</option>
                        </select>
                        <span asp-validation-for="MaNhanVien" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="NgayTruc" class="form-label">
                            <i class="fas fa-calendar me-1"></i>Ngày trực
                        </label>
                        <input asp-for="NgayTruc" type="date" class="form-control" />
                        <span asp-validation-for="NgayTruc" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TenCa" class="form-label">
                            <i class="fas fa-clock me-1"></i>Ca trực
                        </label>
                        <select asp-for="TenCa" class="form-select" asp-items="ViewBag.TenCa">
                            <option value="">-- Chọn ca trực --</option>
                        </select>
                        <span asp-validation-for="TenCa" class="text-danger"></span>
                        <small class="text-muted d-block mt-1">
                            Giờ làm việc sẽ tự động được thiết lập dựa trên ca
                        </small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="GhiChu" class="form-label">
                            <i class="fas fa-sticky-note me-1"></i>Ghi chú
                        </label>
                        <input asp-for="GhiChu" class="form-control" placeholder="Nhập ghi chú (nếu có)" />
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Lưu ca trực
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}