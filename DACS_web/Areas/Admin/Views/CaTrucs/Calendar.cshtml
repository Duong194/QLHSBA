@model IEnumerable<DACS_web.Models.CaTruc>
@using System.Globalization
@{
    ViewData["Title"] = "Lịch ca trực";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedMonth = (DateTime)ViewBag.SelectedMonth;
    var startOfMonth = new DateTime(selectedMonth.Year, selectedMonth.Month, 1);
    var daysInMonth = DateTime.DaysInMonth(selectedMonth.Year, selectedMonth.Month);
    var firstDayOfWeek = (int)startOfMonth.DayOfWeek;
    var cultureInfo = new CultureInfo("vi-VN");
}

@section Styles {
    <link rel="stylesheet" href="~/css/Calendar.css" asp-append-version="true" />
}

<div class="calendar-page">
    <div class="container-fluid py-4">
        <div class="calendar-container">
            <div class="calendar-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <div class="mb-2 mb-md-0">
                        <h3 class="mb-0">
                            <i class="fas fa-calendar-alt me-2"></i>Lịch ca trực
                        </h3>
                        <p class="mb-0 mt-1">Tháng @selectedMonth.Month năm @selectedMonth.Year</p>
                    </div>
                    <div>
                        <a asp-action="Calendar" asp-route-month="@selectedMonth.AddMonths(-1).ToString("yyyy-MM-dd")"
                           class="btn btn-light btn-sm me-2 btn-calendar-nav">
                            <i class="fas fa-chevron-left"></i> Tháng trước
                        </a>
                        <a asp-action="Calendar" class="btn btn-light btn-sm me-2 btn-calendar-nav">
                            <i class="fas fa-calendar-day"></i> Hôm nay
                        </a>
                        <a asp-action="Calendar" asp-route-month="@selectedMonth.AddMonths(1).ToString("yyyy-MM-dd")"
                           class="btn btn-light btn-sm me-2 btn-calendar-nav">
                            Tháng sau <i class="fas fa-chevron-right"></i>
                        </a>
                        <a asp-action="Index" class="btn btn-light btn-sm btn-calendar-nav">
                            <i class="fas fa-list"></i> Danh sách
                        </a>
                    </div>
                </div>
            </div>

            <div class="p-3">
                <div class="table-responsive">
                    <table class="calendar-table">
                        <thead>
                            <tr>
                                <th style="color: #dc3545;">Chủ nhật</th>
                                <th>Thứ 2</th>
                                <th>Thứ 3</th>
                                <th>Thứ 4</th>
                                <th>Thứ 5</th>
                                <th>Thứ 6</th>
                                <th style="color: #0d6efd;">Thứ 7</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var currentDay = 1;
                                var weekCount = (int)Math.Ceiling((firstDayOfWeek + daysInMonth) / 7.0);

                                for (int week = 0; week < weekCount; week++)
                                {
                                    <tr>
                                        @for (int day = 0; day < 7; day++)
                                        {
                                            var cellIndex = week * 7 + day;

                                            if (cellIndex < firstDayOfWeek || currentDay > daysInMonth)
                                            {
                                                <td class="calendar-empty"></td>
                                            }
                                            else
                                            {
                                                var currentDate = new DateTime(selectedMonth.Year, selectedMonth.Month, currentDay);
                                                var isToday = currentDate.Date == DateTime.Today;
                                                var shiftsOnDay = Model.Where(c => c.NgayTruc.Date == currentDate.Date).ToList();

                                                <td class="@(isToday ? "calendar-today" : "")">
                                                    <div class="calendar-date">@currentDay</div>
                                                    @foreach (var shift in shiftsOnDay)
                                                    {
                                                        var tenNhanVien = shift.NhanVien?.HoTen?.Split(' ').LastOrDefault() ?? "";
                                                        <div class="shift-item shift-@shift.TenCa.ToLower()"
                                                             title="@shift.NhanVien?.HoTen - @shift.TenCa (@shift.GioBatDau.ToString(@"hh\:mm") - @shift.GioKetThuc.ToString(@"hh\:mm"))">
                                                            <i class="fas fa-user-circle me-1"></i>
                                                            @tenNhanVien - @shift.TenCa
                                                        </div>
                                                    }
                                                </td>
                                                currentDay++;
                                            }
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="calendar-legend">
                <div class="row">
                    <div class="col-12">
                        <strong><i class="fas fa-info-circle me-2"></i>Chú thích:</strong>
                        <span class="shift-item shift-sang d-inline-block ms-2">
                            <i class="fas fa-sun me-1"></i>Ca Sáng (7:00-12:00)
                        </span>
                        <span class="shift-item shift-chieu d-inline-block ms-2">
                            <i class="fas fa-cloud-sun me-1"></i>Ca Chiều (13:00-18:00)
                        </span>
                        <span class="shift-item shift-toi d-inline-block ms-2">
                            <i class="fas fa-moon me-1"></i>Ca Tối (18:00-22:00)
                        </span>
                        <span class="shift-item shift-dem d-inline-block ms-2">
                            <i class="fas fa-star me-1"></i>Ca Đêm (22:00-7:00)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
