@model DACS_web.Models.BenhNhan

@{
    ViewData["Title"] = "Thêm mới bệnh nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="fas fa-user-plus me-2"></i>@ViewData["Title"]</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay về danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create" id="patientForm">
                        <div asp-validation-summary="All" class="text-danger mb-4"></div>

                        <div class="row">
                            <!-- Thông tin cá nhân -->
                            <div class="col-md-6">
                                <div class="card mb-4">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0"><i class="fas fa-user me-2"></i>Thông tin cá nhân</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label asp-for="HoTen" class="form-label fw-bold">Họ và tên</label>
                                                <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên" />
                                                <span asp-validation-for="HoTen" class="text-danger"></span>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label asp-for="NgaySinh" class="form-label fw-bold">Ngày sinh</label>
                                                <input asp-for="NgaySinh" type="date" class="form-control" />
                                                <span asp-validation-for="NgaySinh" class="text-danger"></span>
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">Giới tính</label>
                                                <div class="mt-2">
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input" type="radio" asp-for="GioiTinh" value="Nam" id="genderMale" checked />
                                                        <label class="form-check-label" for="genderMale">Nam</label>
                                                    </div>
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input" type="radio" asp-for="GioiTinh" value="Nữ" id="genderFemale" />
                                                        <label class="form-check-label" for="genderFemale">Nữ</label>
                                                    </div>
                                                    <span asp-validation-for="GioiTinh" class="text-danger d-block"></span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label asp-for="CMND" class="form-label fw-bold">CMND/CCCD</label>
                                                <input asp-for="CMND" class="form-control" placeholder="Nhập số CMND/CCCD" />
                                                <span asp-validation-for="CMND" class="text-danger"></span>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label asp-for="SoDienThoai" class="form-label fw-bold">Số điện thoại</label>
                                                <input asp-for="SoDienThoai" class="form-control" placeholder="Nhập số điện thoại" />
                                                <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label asp-for="DiaChi" class="form-label fw-bold">Địa chỉ</label>
                                                <input asp-for="DiaChi" class="form-control" placeholder="Nhập địa chỉ" />
                                                <span asp-validation-for="DiaChi" class="text-danger"></span>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label asp-for="DanToc" class="form-label fw-bold">Dân tộc</label>
                                                <input asp-for="DanToc" class="form-control" placeholder="Nhập dân tộc" />
                                                <span asp-validation-for="DanToc" class="text-danger"></span>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label asp-for="QuocTich" class="form-label fw-bold">Quốc tịch</label>
                                                <input asp-for="QuocTich" class="form-control" placeholder="Nhập quốc tịch" value="Việt Nam" />
                                                <span asp-validation-for="QuocTich" class="text-danger"></span>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label asp-for="NgheNghiep" class="form-label fw-bold">Nghề nghiệp</label>
                                                <input asp-for="NgheNghiep" class="form-control" placeholder="Nhập nghề nghiệp" />
                                                <span asp-validation-for="NgheNghiep" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Thông tin bảo hiểm và tiền sử bệnh -->
                            <div class="col-md-6">
                                <div class="card mb-4">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0"><i class="fas fa-heart-pulse me-2"></i>Thông tin bảo hiểm</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label asp-for="DoiTuong" class="form-label fw-bold">Đối tượng</label>
                                                <select asp-for="DoiTuong" class="form-select">
                                                    <option value="">-- Chọn đối tượng --</option>
                                                    <option value="BHYT">Bảo hiểm y tế</option>
                                                    <option value="Thu phí">Thu phí</option>
                                                    <option value="Miễn phí">Miễn phí</option>
                                                </select>
                                                <span asp-validation-for="DoiTuong" class="text-danger"></span>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label asp-for="BHYT" class="form-label fw-bold">Số thẻ BHYT</label>
                                                <input asp-for="BHYT" class="form-control" placeholder="Nhập số thẻ BHYT" />
                                                <span asp-validation-for="BHYT" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-4">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0"><i class="fas fa-notes-medical me-2"></i>Tiền sử bệnh</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label asp-for="TienSuDiUng" class="form-label fw-bold">Tiền sử dị ứng</label>
                                            <textarea asp-for="TienSuDiUng" class="form-control" rows="2" placeholder="Nhập tiền sử dị ứng (nếu có)"></textarea>
                                            <span asp-validation-for="TienSuDiUng" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="TienSuBenhBanThan" class="form-label fw-bold">Tiền sử bệnh bản thân</label>
                                            <textarea asp-for="TienSuBenhBanThan" class="form-control" rows="2" placeholder="Nhập tiền sử bệnh bản thân (nếu có)"></textarea>
                                            <span asp-validation-for="TienSuBenhBanThan" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="TienSuBenhGiaDinh" class="form-label fw-bold">Tiền sử bệnh gia đình</label>
                                            <textarea asp-for="TienSuBenhGiaDinh" class="form-control" rows="2" placeholder="Nhập tiền sử bệnh gia đình (nếu có)"></textarea>
                                            <span asp-validation-for="TienSuBenhGiaDinh" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-center mt-4">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-save me-2"></i>Lưu thông tin
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Thêm validation nếu cần
        $(document).ready(function() {
            // Thêm class is-invalid khi có lỗi validation
            $('form').on('submit', function() {
                if (!$(this).valid()) {
                    $(this).find(':input.input-validation-error').addClass('is-invalid');
                }
            });
        });
    </script>
}