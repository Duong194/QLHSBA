@model DACS_web.Models.BenhNhan

@{
    ViewData["Title"] = "Xóa bệnh nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<h1>@ViewData["Title"]</h1>
<hr />

<h3>Bạn chắc chắn muốn xóa bệnh nhân này?</h3>

<div class="row">
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-4">Họ tên</dt>
            <dd class="col-sm-8">@Model.HoTen</dd>

            <dt class="col-sm-4">Ngày sinh</dt>
            <dd class="col-sm-8">@Model.NgaySinh.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Giới tính</dt>
            <dd class="col-sm-8">@Model.GioiTinh</dd>

            <dt class="col-sm-4">Số điện thoại</dt>
            <dd class="col-sm-8">@Model.SoDienThoai</dd>

            <dt class="col-sm-4">Địa chỉ</dt>
            <dd class="col-sm-8">@Model.DiaChi</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="MaBenhNhan" />
            <button type="submit" class="btn btn-danger">Xóa</button>
            <a asp-action="Index" class="btn btn-secondary">Quay về danh sách</a>
        </form>
    </div>
</div>
