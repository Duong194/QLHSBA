@model IEnumerable<DACS_web.Models.DotKham>

@{
    ViewData["Title"] = "Danh sách đợt khám";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<h2 class="mb-4">@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Thêm đợt khám mới</a>
</p>

<table class="table table-striped table-bordered shadow">
    <thead class="table-dark">
        <tr>
            <th>Mã đợt khám</th>
            <th>Bệnh nhân</th>
            <th>Lý do vào viện</th>
            <th>Ngày vào viện</th>
            <th>Giờ vào viện</th>
            <th>Khoa tiếp nhận</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaDotKham</td>
                <td>@item.BenhNhan?.HoTen</td>
                <td>@item.LyDoVaoVien</td>
                <td>@item.NgayVaoVien.ToString("dd/MM/yyyy")</td>
                <td>@item.GioVaoVien.ToString(@"hh\:mm")</td>
                <td>@item.KhoaTiepNhan?.TenKhoa</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.MaDotKham" class="btn btn-sm btn-warning">✏️ Sửa</a>
                    <a asp-action="Details" asp-route-id="@item.MaDotKham" class="btn btn-sm btn-info">🔍 Xem</a>
                    <a asp-action="Delete" asp-route-id="@item.MaDotKham" class="btn btn-sm btn-danger">🗑 Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
