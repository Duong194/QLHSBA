@model DACS_web.Models.HoSoBenhAn
@{
    ViewData["Title"] = "Lập hồ sơ bệnh án";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var dotKhamInfo = ViewData["DotKhamInfo"] as DACS_web.Models.DotKham;
}

<div class="container-fluid py-4">
    <!-- Success Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fas fa-file-medical me-2"></i>@ViewData["Title"]</h4>
        </div>

        <div class="card-body">
            <!-- ✅ Hiển thị thông tin đợt khám nếu có -->
            @if (dotKhamInfo != null)
            {
                <div class="alert alert-info">
                    <h5 class="alert-heading">
                        <i class="fas fa-info-circle"></i> Thông tin đợt khám
                    </h5>
                    <hr>
                    <div class="row">
                        <div class="col-md-3">
                            <strong>Mã đợt khám:</strong><br>
                            <span class="badge bg-primary fs-6">@dotKhamInfo.MaDotKham</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Bệnh nhân:</strong><br>
                            @dotKhamInfo.BenhNhan?.HoTen
                        </div>
                        <div class="col-md-3">
                            <strong>Ngày vào viện:</strong><br>
                            @dotKhamInfo.NgayVaoVien.ToString("dd/MM/yyyy")
                        </div>
                        <div class="col-md-3">
                            <strong>Khoa:</strong><br>
                            @dotKhamInfo.KhoaTiepNhan?.TenKhoa
                        </div>
                    </div>
                    <div class="mt-2">
                        <strong>Lý do vào viện:</strong> @dotKhamInfo.LyDoVaoVien
                    </div>
                </div>
            }

            <!-- Hiển thị lỗi tổng quát -->
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong><i class="fas fa-exclamation-triangle me-2"></i>Lỗi lưu dữ liệu:</strong>
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="Create" id="hoSoBenhAnForm">
                <!-- ✅ Hidden fields cho MaDotKham và MaBenhNhan -->
                <input type="hidden" asp-for="MaDotKham" />
                <input type="hidden" asp-for="MaBenhNhan" />

                <!-- Thông tin cơ bản -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-user-injured me-2"></i>Thông tin cơ bản</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <!-- Bệnh nhân (readonly nếu từ DotKham) -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Bệnh nhân <span class="text-danger">*</span></label>
                                @if (dotKhamInfo != null)
                                {
                                    <input type="text" class="form-control bg-light"
                                           value="@dotKhamInfo.MaBenhNhan - @dotKhamInfo.BenhNhan?.HoTen" readonly />
                                }
                                else
                                {
                                    <select asp-for="MaBenhNhan" class="form-select" asp-items="ViewBag.MaBenhNhan" required>
                                        <option value="">-- Chọn bệnh nhân --</option>
                                    </select>
                                    <span asp-validation-for="MaBenhNhan" class="text-danger"></span>
                                }
                            </div>

                            <!-- Đợt khám (readonly nếu từ DotKham) -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Đợt khám <span class="text-danger">*</span></label>
                                @if (dotKhamInfo != null)
                                {
                                    <input type="text" class="form-control bg-light" value="@dotKhamInfo.MaDotKham" readonly />
                                }
                                else
                                {
                                    <input type="text" class="form-control bg-light" value="Chưa có đợt khám" readonly />
                                    <small class="text-muted">Vui lòng tạo đợt khám trước</small>
                                }
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="NgayTao" class="form-control" type="date"
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                    <label asp-for="NgayTao">Ngày tạo hồ sơ <span class="text-danger">*</span></label>
                                    <span asp-validation-for="NgayTao" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <select asp-for="TrangThaiRaVien" class="form-select" required>
                                        <option value="Đang điều trị" selected>Đang điều trị</option>
                                        <option value="Đã ra viện">Đã ra viện</option>
                                        <option value="Chuyển viện">Chuyển viện</option>
                                        <option value="Tự xuất viện">Tự xuất viện</option>
                                    </select>
                                    <label asp-for="TrangThaiRaVien">Trạng thái <span class="text-danger">*</span></label>
                                    <span asp-validation-for="TrangThaiRaVien" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Thông tin bác sĩ -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-user-md me-2"></i>Thông tin bác sĩ</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <select asp-for="MaBacSiLapBenhAn" class="form-select" asp-items="ViewBag.MaBacSiLapBenhAn" required>
                                        <option value="">-- Chọn bác sĩ lập bệnh án --</option>
                                    </select>
                                    <label asp-for="MaBacSiLapBenhAn">Bác sĩ lập bệnh án <span class="text-danger">*</span></label>
                                    <span asp-validation-for="MaBacSiLapBenhAn" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <select asp-for="MaBacSiDieuTri" class="form-select" asp-items="ViewBag.MaBacSiDieuTri" required>
                                        <option value="">-- Chọn bác sĩ điều trị --</option>
                                    </select>
                                    <label asp-for="MaBacSiDieuTri">Bác sĩ điều trị <span class="text-danger">*</span></label>
                                    <span asp-validation-for="MaBacSiDieuTri" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tiên lượng -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-heartbeat me-2"></i>Tiên lượng</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <textarea asp-for="TienLuongGan" class="form-control" style="height: 100px"></textarea>
                                    <label asp-for="TienLuongGan">Tiên lượng gần</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <textarea asp-for="TienLuongXa" class="form-control" style="height: 100px"></textarea>
                                    <label asp-for="TienLuongXa">Tiên lượng xa</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <div>
                        @if (dotKhamInfo != null)
                        {
                            <a asp-action="Details" asp-controller="DotKhams" asp-route-id="@dotKhamInfo.MaDotKham"
                               class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Quay lại đợt khám
                            </a>
                        }
                        else
                        {
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Quay lại danh sách
                            </a>
                        }
                    </div>
                    <div>
                        <button type="reset" class="btn btn-outline-secondary me-2">
                            <i class="fas fa-undo me-1"></i>Làm mới
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Lưu hồ sơ
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}