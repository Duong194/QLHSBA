@model DACS_web.Models.HinhAnhYTe
@{
    ViewData["Title"] = "Chỉnh sửa ảnh y tế";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container-fluid py-4">
    <!-- Header và breadcrumb -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-0">@ViewData["Title"]</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-controller="HoSoBenhAns" asp-action="Index">Danh sách hồ sơ</a></li>
                    <li class="breadcrumb-item"><a asp-controller="HoSoBenhAns" asp-action="Details" asp-route-id="@Model.MaHoSo">Chi tiết hồ sơ</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa ảnh y tế</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-image me-2"></i>Thông tin ảnh y tế</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" enctype="multipart/form-data" method="post">
                        <input type="hidden" asp-for="MaAnh" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="MaHoSo" class="form-label">Mã hồ sơ</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-folder-open"></i></span>
                                        <input asp-for="MaHoSo" class="form-control" readonly />
                                    </div>
                                    <span asp-validation-for="MaHoSo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="LoaiHinh" class="form-label">Loại hình ảnh <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                        <select asp-for="LoaiHinh" class="form-select" required>
                                            <option value="">-- Chọn loại hình ảnh --</option>
                                            <option value="CT Scan">CT Scan</option>
                                            <option value="X-quang">X-quang</option>
                                            <option value="Siêu âm">Siêu âm</option>
                                            <option value="MRI">MRI</option>
                                            <option value="Nội soi">Nội soi</option>
                                            <option value="Khác">Khác</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="LoaiHinh" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MoTa" class="form-label">Mô tả chi tiết</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-comment-medical"></i></span>
                                <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Nhập mô tả chi tiết về hình ảnh y tế"></textarea>
                            </div>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Cập nhật ảnh mới (nếu cần)</label>
                            <div class="input-group mb-3">
                                <span class="input-group-text"><i class="fas fa-file-upload"></i></span>
                                <input type="file" name="uploadFile" id="uploadFile" class="form-control" accept="image/*" onchange="previewImage(event)" />
                            </div>
                            <span class="text-danger" asp-validation-for="FileURL"></span>
                            <div class="form-text text-muted">Hỗ trợ các định dạng: JPG, PNG, GIF. Kích thước tối đa: 5MB</div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Details" asp-controller="HoSoBenhAns" asp-route-id="@Model.MaHoSo" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-eye me-2"></i>Xem trước ảnh</h5>
                </div>
                <div class="card-body text-center">
                    <div class="position-relative mb-3">
                        <img id="preview" src="@Model.FileURL" style="max-width: 100%; max-height: 300px;" class="img-thumbnail" />
                    </div>
                    <div class="alert alert-info mb-0 mt-3">
                        <i class="fas fa-info-circle me-2"></i>
                        <small>Hình ảnh y tế rõ nét sẽ giúp cho việc chẩn đoán và theo dõi điều trị được chính xác hơn.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        function previewImage(event) {
            var input = event.target;
            var reader = new FileReader();
            reader.onload = function () {
                var preview = document.getElementById('preview');
                preview.src = reader.result;
            };
            if (input.files[0]) {
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Thiết lập giá trị cho LoaiHinh khi trang tải xong
        $(document).ready(function() {
            var loaiHinh = "@Model.LoaiHinh";
            if (loaiHinh) {
                $("#LoaiHinh").val(loaiHinh);
            }
        });
    </script>
}