@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="dashboard-wrapper">
    <div class="dashboard-main">
        <!-- Header Section -->
        <div class="dash-header">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <div class="dash-welcome">
                            <h1 class="dash-title">
                                <span class="dash-greeting">Xin chào,</span>
                                <span class="dash-username">@ViewBag.UserName</span>
                            </h1>
                            <p class="dash-subtitle">Chào mừng bạn quay trở lại hệ thống quản lý bệnh viện</p>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="dash-header-info">
                            <div class="dash-time">
                                <i class="far fa-clock"></i>
                                <span id="current-time"></span>
                            </div>
                            <div class="dash-role @(role == "Admin" ? "role-admin" : role == "BacSi" ? "role-doctor" : "role-nurse")">
                                <i class="fas @(role == "Admin" ? "fa-user-shield" : role == "BacSi" ? "fa-user-md" : "fa-user-nurse")"></i>
                                <span>@role</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container-fluid py-4">
            @if (role == "Admin")
            {
                <!-- Admin Stats Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-primary">
                            <div class="dash-stats-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">1,234</h3>
                                <p class="dash-stats-label">Tổng người dùng</p>
                                <div class="dash-stats-trend positive">
                                    <i class="fas fa-arrow-up"></i> 12% so với tháng trước
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-success">
                            <div class="dash-stats-icon">
                                <i class="fas fa-user-injured"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">856</h3>
                                <p class="dash-stats-label">Bệnh nhân đang điều trị</p>
                                <div class="dash-stats-trend positive">
                                    <i class="fas fa-arrow-up"></i> 8% tuần này
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-info">
                            <div class="dash-stats-icon">
                                <i class="fas fa-file-medical"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">342</h3>
                                <p class="dash-stats-label">Hồ sơ mới hôm nay</p>
                                <div class="dash-stats-trend neutral">
                                    <i class="fas fa-minus"></i> Không đổi
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-warning">
                            <div class="dash-stats-icon">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">127</h3>
                                <p class="dash-stats-label">Lịch hẹn hôm nay</p>
                                <div class="dash-stats-trend negative">
                                    <i class="fas fa-arrow-down"></i> 5% so với hôm qua
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Access Section -->
                <div class="dash-section-header">
                    <h2 class="dash-section-title">
                        <i class="fas fa-th-large me-2"></i>
                        Truy cập nhanh
                    </h2>
                    <p class="dash-section-subtitle">Các chức năng quản trị chính của hệ thống</p>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="User" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-primary">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Quản lý người dùng</h5>
                                <p class="dash-feature-desc">Quản lý tài khoản và phân quyền</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="NhanVienYTes" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-success">
                                <i class="fas fa-user-md"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Quản lý nhân viên</h5>
                                <p class="dash-feature-desc">Bác sĩ, y tá và nhân viên y tế</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="BenhNhans" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-danger">
                                <i class="fas fa-user-injured"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Danh sách bệnh nhân</h5>
                                <p class="dash-feature-desc">Quản lý hồ sơ bệnh nhân</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="CaTrucs" asp-action="Index" class="dash-feature-card">
