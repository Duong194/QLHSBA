                                <p class="dash-feature-desc">Danh sách thuốc điều trị</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="Khoas" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-secondary">
                                <i class="fas fa-hospital"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Các khoa</h5>
                                <p class="dash-feature-desc">Thông tin các khoa</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="BaiBaos" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-dark">
                                <i class="fas fa-newspaper"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Bài báo</h5>
                                <p class="dash-feature-desc">Quản lý bài viết</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Ca Trực Hôm Nay Section -->
                @await Html.PartialAsync("_AdminShiftsToday")
            }
            else if (role == "BacSi")
            {
                <!-- Doctor Dashboard -->
                <div class="row g-4 mb-4">
                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-info">
                            <div class="dash-stats-icon">
                                <i class="fas fa-user-injured"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">45</h3>
                                <p class="dash-stats-label">Bệnh nhân của tôi</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-success">
                            <div class="dash-stats-icon">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">12</h3>
                                <p class="dash-stats-label">Lịch hẹn hôm nay</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-warning">
                            <div class="dash-stats-icon">
                                <i class="fas fa-pills"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">28</h3>
                                <p class="dash-stats-label">Đơn thuốc tuần này</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="dash-stats-card stats-primary">
                            <div class="dash-stats-icon">
                                <i class="fas fa-file-medical"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">156</h3>
                                <p class="dash-stats-label">Hồ sơ đã xử lý</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="dash-section-header">
                    <h2 class="dash-section-title">
                        <i class="fas fa-stethoscope me-2"></i>
                        Công cụ làm việc
                    </h2>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-xl-3 col-lg-6">
                        <a asp-controller="HoSoBenhAns" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-info">
                                <i class="fas fa-file-medical"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Hồ sơ bệnh án</h5>
                                <p class="dash-feature-desc">Quản lý hồ sơ bệnh nhân</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-6">
                        <a asp-controller="BenhNhans" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-danger">
                                <i class="fas fa-user-injured"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Danh sách bệnh nhân</h5>
                                <p class="dash-feature-desc">Xem thông tin bệnh nhân</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-6">
                        <a asp-controller="CuocHenKhams" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-primary">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Lịch hẹn</h5>
                                <p class="dash-feature-desc">Quản lý lịch hẹn khám</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-6">
                        <a asp-area="Admin" asp-controller="CaTrucs" asp-action="MyShifts" class="dash-feature-card">
                            <div class="dash-feature-icon bg-warning">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Ca trực của tôi</h5>
                                <p class="dash-feature-desc">Xem lịch trực cá nhân</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Ca Trực Của Bác Sĩ -->
                @await Html.PartialAsync("_DoctorAppointmentsWidget")
                @await Html.PartialAsync("_MyShiftsWidget")
            }
            else if (role == "YTa")
            {
                <!-- Nurse Dashboard -->
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="dash-stats-card stats-info">
                            <div class="dash-stats-icon">
                                <i class="fas fa-comments"></i>
                            </div>
                            <div class="dash-stats-content">
                                <h3 class="dash-stats-number">18</h3>
