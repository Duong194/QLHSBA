                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Quản lý ca trực</h5>
                                <p class="dash-feature-desc">Phân công lịch làm việc</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="HoSoBenhAns" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-warning">
                                <i class="fas fa-file-medical"></i>
                            </div>
                            <div class="dash-feature-content">
                                <h5 class="dash-feature-title">Hồ sơ bệnh án</h5>
                                <p class="dash-feature-desc">Lịch sử khám chữa bệnh</p>
                            </div>
                            <div class="dash-feature-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </a>
                    </div>

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <a asp-controller="Thuocs" asp-action="Index" class="dash-feature-card">
                            <div class="dash-feature-icon bg-teal">
                                <i class="fas fa-capsules"></i>
                            </div>
                            <div class="dash-feature-content">
