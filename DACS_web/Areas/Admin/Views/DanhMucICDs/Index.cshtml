@model IEnumerable<DACS_web.Models.DanhMucICD>

@{
    ViewData["Title"] = "Danh sách bệnh ICD";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">
                <i class="fas fa-clipboard-list me-2"></i>@ViewData["Title"]
            </h3>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus-circle me-1"></i>Thêm mới
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="icdTable" class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Mã ICD</th>
                            <th>Tên bệnh</th>
                            <th style="width: 200px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-info text-dark">@item.MaICD</span></td>
                                <td>@item.TenBenh</td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.MaICD" class="btn btn-warning btn-sm">
                                            <i class="fas fa-edit me-1"></i>Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaICD" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash-alt me-1"></i>Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#icdTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.25/i18n/Vietnamese.json"
                },
                "pageLength": 10,
                "ordering": true,
                "responsive": true
            });
        });
    </script>
}