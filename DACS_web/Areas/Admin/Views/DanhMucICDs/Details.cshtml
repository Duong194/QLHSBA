@model DACS_web.Models.DanhMucICD

@{
    ViewData["Title"] = "Chi tiết bệnh ICD";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<h2>@ViewData["Title"]</h2>

<dl class="row">
    <dt class="col-sm-3">Mã ICD</dt>
    <dd class="col-sm-9">@Model.MaICD</dd>

    <dt class="col-sm-3">Tên bệnh</dt>
    <dd class="col-sm-9">@Model.TenBenh</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.MaICD" class="btn btn-warning">Sửa</a>
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>
