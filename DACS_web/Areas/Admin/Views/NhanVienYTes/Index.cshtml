@model IEnumerable<DACS_web.Models.NhanVienYTe>

@{
    ViewData["Title"] = "Danh sách nhân viên y tế";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="text-primary">
                <i class="fas fa-user-md me-2"></i>
                @ViewData["Title"]
            </h1>
            <p class="text-muted">Quản lý thông tin nhân viên y tế trong hệ thống</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success btn-lg">
                <i class="fas fa-plus me-2"></i>Thêm nhân viên mới
            </a>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="card-title mb-0">
                <i class="fas fa-search me-2"></i>Tìm kiếm và lọc dữ liệu
            </h5>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="searchString" class="form-label">Tìm kiếm:</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="fas fa-search"></i>
                            </span>
                            <input type="text"
                                   class="form-control"
                                   id="searchString"
                                   name="searchString"
                                   value="@ViewBag.SearchString"
                                   placeholder="Nhập tên, mã nhân viên hoặc số điện thoại...">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label for="vaiTroFilter" class="form-label">Vai trò:</label>
                        <select class="form-select" id="vaiTroFilter" name="vaiTroFilter">
                            <option value="">-- Tất cả vai trò --</option>
                            @if (ViewBag.VaiTroList != null)
                            {
                                @foreach (var vaiTro in ViewBag.VaiTroList as IEnumerable<SelectListItem>)
                                {
                                    <option value="@vaiTro.Value" selected="@(vaiTro.Value == ViewBag.VaiTroFilter)">
                                        @vaiTro.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="khoaFilter" class="form-label">Khoa:</label>
                        <select class="form-select" id="khoaFilter" name="khoaFilter">
                            <option value="">-- Tất cả khoa --</option>
                            @if (ViewBag.KhoaList != null)
                            {
                                @foreach (var khoa in ViewBag.KhoaList as IEnumerable<SelectListItem>)
                                {
                                    <option value="@khoa.Value" selected="@(khoa.Value == ViewBag.KhoaFilter)">
                                        @khoa.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="btn-group w-100" role="group">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-search me-1"></i>Tìm
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                <i class="fas fa-refresh me-1"></i>Reset
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Summary -->
    <div class="row mb-3">
        <div class="col-md-6">
            <p class="text-muted">
                <i class="fas fa-info-circle me-1"></i>
                Tìm thấy <strong>@Model.Count()</strong> nhân viên
                @if (!string.IsNullOrEmpty(ViewBag.SearchString as string) ||
                !string.IsNullOrEmpty(ViewBag.VaiTroFilter as string) ||
                !string.IsNullOrEmpty(ViewBag.KhoaFilter as string))
                {
                    <span class="badge bg-primary ms-2">Đã lọc</span>
                }
            </p>
        </div>       
    </div>

    <!-- Data Table -->
    <div class="card">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0" id="nhanvienTable">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center">#</th>
                                <th>
                                    <i class="fas fa-id-card me-1"></i>Mã nhân viên
                                </th>
                                <th>
                                    <i class="fas fa-user me-1"></i>Họ tên
                                </th>
                                <th>
                                    <i class="fas fa-user-tag me-1"></i>Vai trò
                                </th>
                                <th>
                                    <i class="fas fa-phone me-1"></i>Số điện thoại
                                </th>
                                <th>
                                    <i class="fas fa-building me-1"></i>Khoa
                                </th>
                                <th class="text-center">
                                    <i class="fas fa-cogs me-1"></i>Thao tác
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted">@index</td>
                                    <td>
                                        <span class="badge bg-secondary">@item.MaNhanVien</span>
                                    </td>
                                    <td>
                                        <strong>@item.HoTen</strong>
                                    </td>
                                    <td>
                                        @{
                                            string badgeClass = item.VaiTro switch
                                            {
                                                "Bác sĩ" => "bg-success",
                                                "Y tá" => "bg-info",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@item.VaiTro</span>
                                    </td>
                                    <td>
                                        <i class="fas fa-phone-alt text-muted me-1"></i>
                                        @item.SoDienThoai
                                    </td>
                                    <td>
                                        <i class="fas fa-hospital text-muted me-1"></i>
                                        @(item.Khoa?.TenKhoa ?? "Chưa xác định")
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group" aria-label="Actions">                                            
                                            <a asp-action="Edit"
                                               asp-route-id="@item.MaNhanVien"
                                               class="btn btn-warning btn-sm"
                                               title="Chỉnh sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete"
                                               asp-route-id="@item.MaNhanVien"
                                               class="btn btn-danger btn-sm"
                                               title="Xóa"
                                               onclick="return confirm('Bạn có chắc chắn muốn xóa nhân viên này?')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="fas fa-search fa-3x text-muted"></i>
                    </div>
                    <h5 class="text-muted">Không tìm thấy nhân viên nào</h5>
                    <p class="text-muted">
                        @if (!string.IsNullOrEmpty(ViewBag.SearchString as string) ||
                       !string.IsNullOrEmpty(ViewBag.VaiTroFilter as string) ||
                       !string.IsNullOrEmpty(ViewBag.KhoaFilter as string))
                        {
                            <span>Thử thay đổi từ khóa tìm kiếm hoặc xóa bộ lọc</span>
                        }
                        else
                        {
                            <span>Chưa có nhân viên nào trong hệ thống</span>
                        }
                    </p>
                    <a href="@Url.Action("Index")" class="btn btn-primary">
                        <i class="fas fa-refresh me-1"></i>Làm mới
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto submit form on filter change
        document.getElementById('vaiTroFilter').addEventListener('change', function() {
            this.form.submit();
        });

        document.getElementById('khoaFilter').addEventListener('change', function() {
            this.form.submit();
        });

        // Export to Excel function
        function exportToExcel() {
            // You can implement Excel export functionality here
            alert('Chức năng xuất Excel đang được phát triển');
        }

        // Print table function
        function printTable() {
            var printContent = document.getElementById('nhanvienTable').outerHTML;
            var originalContent = document.body.innerHTML;

            document.body.innerHTML = `
                <div style="text-align: center; margin-bottom: 20px;">
                    <h2>Danh sách nhân viên y tế</h2>
                    <p>Ngày in: ${new Date().toLocaleDateString('vi-VN')}</p>
                </div>
                ${printContent}
            `;

            window.print();
            document.body.innerHTML = originalContent;
            window.location.reload();
        }

        // Highlight search terms
        @if (!string.IsNullOrEmpty(ViewBag.SearchString as string))
        {
            <text>
                document.addEventListener('DOMContentLoaded', function() {
                    var searchTerm = '@ViewBag.SearchString';
                    if (searchTerm && searchTerm.length > 0) {
                        var regex = new RegExp('(' + searchTerm + ')', 'gi');
                        var tableBody = document.querySelector('#nhanvienTable tbody');
                        if (tableBody) {
                            tableBody.innerHTML = tableBody.innerHTML.replace(regex, '<mark>$1</mark>');
                        }
                    }
                });
            </text>
        }
    </script>
}