@model IEnumerable<DACS_web.Models.Khoa>
@{
    ViewData["Title"] = "Danh sách các khoa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Header với hiệu ứng đổ bóng nhẹ -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="card-title mb-0 text-primary">
                    <i class="fas fa-university me-2"></i>@ViewData["Title"]
                </h2>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus-circle me-1"></i>Thêm khoa mới
                </a>
            </div>
        </div>
    </div>

    <!-- Card chứa form tìm kiếm -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label for="searchString" class="form-label">Tìm kiếm theo tên khoa</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control" id="searchString" name="searchString"
                               placeholder="Nhập tên khoa cần tìm..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex">
                        <button type="submit" class="btn btn-primary me-2">
                            <i class="fas fa-search me-1"></i>Tìm kiếm
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-redo me-1"></i>Đặt lại
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Card chứa bảng dữ liệu -->
    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th scope="col">Mã khoa</th>
                                <th scope="col">Tên khoa</th>
                                <th scope="col">Mô tả</th>
                                <th scope="col" class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.MaKhoa</td>
                                    <td>
                                        <span class="fw-medium">@item.TenKhoa</span>
                                    </td>
                                    <td>@item.MoTa</td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">                                           
                                            <a asp-action="Edit" asp-route-id="@item.MaKhoa" class="btn btn-warning btn-sm mx-1" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaKhoa" class="btn btn-danger btn-sm mx-1" title="Xóa">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                    <p class="lead">Không tìm thấy khoa nào</p>
                    <p class="text-muted">Hãy thử tìm kiếm với từ khóa khác hoặc tạo mới khoa.</p>
                </div>
            }
        </div>
    </div>

    <!-- Hiển thị số lượng khoa -->
    <div class="mt-3 text-muted small">
        <i class="fas fa-info-circle me-1"></i>
        Hiển thị @(Model?.Count() ?? 0) khoa
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Hiệu ứng hover cho các hàng trong bảng
            $('tbody tr').hover(
                function() {
                    $(this).addClass('table-active');
                },
                function() {
                    $(this).removeClass('table-active');
                }
            );

            // Thêm hiệu ứng confirm xóa
            $('a[asp-action="Delete"]').click(function(e) {
                if (!confirm('Bạn có chắc chắn muốn xóa khoa này?')) {
                    e.preventDefault();
                }
            });
        });
    </script>
}