@model DACS_web.Models.Khoa
@{
    ViewData["Title"] = "Thêm khoa mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Header với hiệu ứng đổ bóng nhẹ -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="card-title mb-0 text-primary">
                    <i class="fas fa-plus-circle me-2"></i>@ViewData["Title"]
                </h2>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Quay về danh sách
                </a>
            </div>
        </div>
    </div>

    <!-- Card chứa form -->
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert">
                    <p class="mb-0"><strong><i class="fas fa-exclamation-triangle me-1"></i>Vui lòng kiểm tra lại thông tin:</strong></p>
                </div>

                <input asp-for="MaKhoa" type="hidden" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-4">
                            <label asp-for="TenKhoa" class="form-label fw-medium">Tên khoa <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-university"></i></span>
                                <input asp-for="TenKhoa" class="form-control" placeholder="Nhập tên khoa..." />
                            </div>
                            <span asp-validation-for="TenKhoa" class="text-danger"></span>
                            <div class="form-text">Tên khoa nên ngắn gọn và mô tả chính xác</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MoTa" class="form-label fw-medium">Mô tả</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-info-circle"></i></span>
                                <textarea asp-for="MoTa" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết về khoa..."></textarea>
                            </div>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                            <div class="form-text">Mô tả nên cung cấp thông tin chi tiết về các ngành học, đặc điểm của khoa</div>
                        </div>

                        <div class="mt-4">
                            <hr />
                            <div class="d-flex">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-1"></i>Thêm mới
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-1"></i>Hủy
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5 class="card-title"><i class="fas fa-lightbulb me-2"></i>Hướng dẫn</h5>
                                <p class="card-text small">
                                    Khi tạo một khoa mới, hãy đảm bảo:
                                </p>
                                <ul class="small">
                                    <li>Tên khoa không trùng lặp với các khoa đã có</li>
                                    <li>Mô tả rõ ràng về các ngành học, hoạt động của khoa</li>
                                    <li>Kiểm tra kỹ thông tin trước khi lưu</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Kiểm tra trường đã được điền chưa khi người dùng rời khỏi trường nhập liệu
        $(document).ready(function() {
            $('input, textarea').blur(function() {
                if ($(this).val().trim() === '' && $(this).attr('required')) {
                    $(this).addClass('is-invalid');
                } else {
                    $(this).removeClass('is-invalid').addClass('is-valid');
                }
            });
        });
    </script>
}