@model DACS_web.Models.BaiBao
@{
    ViewData["Title"] = "Chi tiết bài báo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a <a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
        </ol>
    </nav>

    <div class="card shadow">
        <div class="card-header bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0">@Model.TieuDe</h1>
                <div>
                    @if (User.IsInRole(SD.Role_Admin))
                    {
                        <a asp-area="Admin" asp-controller="BaiBaos" asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-primary">
                            <i class="bi bi-pencil"></i> Chỉnh sửa
                        </a>
                        <a asp-area="Admin" asp-controller="BaiBaos" asp-action="index" asp-route-id="@Model?.Id" class="btn btn-outline-primary">
                            <i class="bi bi-pencil"></i> Quay lại
                        </a>
                    }
         
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-4">
                        <div class="d-flex align-items-center text-muted mb-3">
                            <span class="me-3"><i class="bi bi-person"></i> @Model.TacGia</span>
                            <span class="me-3"><i class="bi bi-calendar"></i> @Model.NgayDang.ToString("dd/MM/yyyy HH:mm")</span>
                            <span><i class="bi bi-tag"></i> @Model.DanhMuc</span>
                        </div>

                        <div class="article-content mt-4">
                            @Html.Raw(Model.NoiDung)
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(Model.HinhAnh))
                    {
                        <div class="text-center mb-4">
                            <img src="@Model.HinhAnh" class="img-fluid rounded shadow-sm" alt="@Model.TieuDe" style="max-height: 300px; width: 100%; object-fit: cover;">
                            <small class="d-block text-muted mt-2">Hình ảnh bài báo</small>
                        </div>
                    }

                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Thông tin bài báo</h5>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Danh mục:</dt>
                                <dd class="col-sm-8 mb-2">@Model.DanhMuc</dd>

                                <dt class="col-sm-4">Tác giả:</dt>
                                <dd class="col-sm-8 mb-2">@Model.TacGia</dd>

                                <dt class="col-sm-4">Ngày đăng:</dt>
                                <dd class="col-sm-8 mb-2">@Model.NgayDang.ToString("dd/MM/yyyy HH:mm")</dd>

                                <dt class="col-sm-4">Mã bài:</dt>
                                <dd class="col-sm-8">@Model.Id</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Bootstrap Icons and TinyMCE CSS for better content display -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css">
<style>
    .article-content {
        line-height: 1.8;
    }

        .article-content img {
            max-width: 100%;
            height: auto;
            margin: 1rem 0;
        }
</style>