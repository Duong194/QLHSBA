@model IEnumerable<DACS_web.Models.Thuoc>
@{
    ViewData["Title"] = "Danh sách thuốc";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Liên kết file CSS riêng *@
<link rel="stylesheet" href="~/css/medicine-list.css" />

<div class="medicine-list-wrapper">
    <div class="container-fluid py-4">
        <div class="card shadow">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-capsules me-2"></i>@ViewData["Title"]</h4>
                <a asp-action="Create" class="btn btn-light"><i class="fas fa-plus-circle me-1"></i>Thêm thuốc mới</a>
            </div>

            <div class="card-body">
                <!-- Bộ lọc và tìm kiếm -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="input-group">
                            <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm thuốc theo tên, mã, chỉ định...">
                            <button class="btn btn-outline-secondary" type="button">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="filterUnit">
                            <option value="">-- Lọc theo đơn vị tính --</option>
                            <option value="Viên">Viên</option>
                            <option value="Vỉ">Vỉ</option>
                            <option value="Hộp">Hộp</option>
                            <option value="Chai">Chai</option>
                            <option value="Ống">Ống</option>
                            <option value="Tuýp">Tuýp</option>
                        </select>
                    </div>
                    <div class="col-md-3 text-md-end">
                        <button class="btn btn-outline-success" id="refreshBtn">
                            <i class="fas fa-sync-alt me-1"></i>Làm mới
                        </button>
                    </div>
                </div>

                <!-- Hiển thị số lượng bản ghi -->
                <p class="text-muted mb-3">Hiển thị <span class="fw-bold" id="recordCount">@Model.Count()</span> loại thuốc</p>

                <!-- Grid hiển thị cards -->
                <div class="row g-3" id="cardContainer">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-6 col-lg-4 med-card-item">
                            <div class="card h-100 shadow-sm med-hover-effect">
                                <!-- Header của card -->
                                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0 text-success">
                                        <i class="fas fa-pills me-2"></i>@item.MaThuoc
                                    </h6>
                                    <span class="badge bg-success med-unit-badge">@item.DonViTinh</span>
                                </div>

                                <!-- Nội dung card -->
                                <div class="card-body">
                                    <!-- Tên thuốc -->
                                    <h5 class="med-title">@item.TenThuoc</h5>

                                    <!-- Đơn giá -->
                                    <div class="med-price-section">
                                        <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded">
                                            <div>
                                                <small class="text-muted d-block">Đơn giá</small>
                                                <strong class="text-success fs-5">@item.DonGia.ToString("N0") VNĐ</strong>
                                            </div>
                                            <i class="fas fa-money-bill-wave fa-2x text-success opacity-50"></i>
                                        </div>
                                    </div>

                                    <!-- Chỉ định -->
                                    <div class="mb-3">
                                        <div class="d-flex align-items-start">
                                            <i class="fas fa-book-medical text-info me-2 mt-1"></i>
                                            <div>
                                                <small class="text-muted d-block">Chỉ định</small>
                                                <span class="med-indication">@(item.ChiDinh ?? "Chưa có thông tin")</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Tác dụng phụ -->
                                    @if (!string.IsNullOrEmpty(item.TacDungPhu))
                                    {
                                        <div class="mb-3">
                                            <div class="alert alert-warning py-2 px-3 mb-0">
                                                <small class="d-flex align-items-start">
                                                    <i class="fas fa-exclamation-triangle me-2 mt-1"></i>
                                                    <div>
                                                        <strong class="d-block">Tác dụng phụ:</strong>
                                                        <span class="med-side-effect">@item.TacDungPhu</span>
                                                    </div>
                                                </small>
                                            </div>
                                        </div>
                                    }

                                    <!-- Tương tác thuốc -->
                                    @if (!string.IsNullOrEmpty(item.TuongTacThuoc))
                                    {
                                        <div class="mb-2">
                                            <div class="alert alert-danger py-2 px-3 mb-0">
                                                <small class="d-flex align-items-start">
                                                    <i class="fas fa-times-circle me-2 mt-1"></i>
                                                    <div>
                                                        <strong class="d-block">Tương tác thuốc:</strong>
                                                        <span class="med-interaction">@item.TuongTacThuoc</span>
                                                    </div>
                                                </small>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <!-- Footer của card với các nút thao tác -->
                                <div class="card-footer bg-transparent border-top">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Details" asp-route-id="@item.MaThuoc"
                                           class="btn btn-sm btn-outline-info" data-bs-toggle="tooltip" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaThuoc"
                                           class="btn btn-sm btn-outline-warning" data-bs-toggle="tooltip" title="Sửa">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaThuoc"
                                           class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Phân trang -->
                <div class="row mt-4">
                    <div class="col-12">
                        <nav aria-label="Page navigation" class="d-flex justify-content-center">
                            <ul class="pagination">
                                <li class="page-item disabled">
                                    <a class="page-link" href="#" tabindex="-1" aria-disabled="true">Trước</a>
                                </li>
                                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                <li class="page-item"><a class="page-link" href="#">2</a></li>
                                <li class="page-item"><a class="page-link" href="#">3</a></li>
                                <li class="page-item">
                                    <a class="page-link" href="#">Tiếp</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Kích hoạt tooltips
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Xử lý tìm kiếm
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchText = this.value.toLowerCase();
            const cards = document.querySelectorAll('.med-card-item');
            let visibleCount = 0;

            cards.forEach(card => {
                const cardText = card.textContent.toLowerCase();
                if (cardText.includes(searchText)) {
                    card.style.display = '';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            document.getElementById('recordCount').textContent = visibleCount;
        });

        // Xử lý lọc theo đơn vị tính
        document.getElementById('filterUnit').addEventListener('change', function() {
            const filterValue = this.value;
            const cards = document.querySelectorAll('.med-card-item');
            let visibleCount = 0;

            cards.forEach(card => {
                const unitBadge = card.querySelector('.med-unit-badge');

                if (filterValue === '' || unitBadge.textContent.trim() === filterValue) {
                    card.style.display = '';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            document.getElementById('recordCount').textContent = visibleCount;
        });

        // Nút làm mới
        document.getElementById('refreshBtn').addEventListener('click', function() {
            document.getElementById('searchInput').value = '';
            document.getElementById('filterUnit').selectedIndex = 0;

            const cards = document.querySelectorAll('.med-card-item');
            cards.forEach(card => {
                card.style.display = '';
            });

            document.getElementById('recordCount').textContent = cards.length;
        });
    });
</script>