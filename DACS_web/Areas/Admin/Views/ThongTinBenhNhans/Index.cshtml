@model DACS_web.Models.ThongTinBenhNhan

@{
    ViewData["Title"] = "Thông tin bệnh nhân và hồ sơ bệnh án";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<h2 class="mb-4">@ViewData["Title"]</h2>

<!-- Thông tin bệnh nhân -->
<div class="card mb-5 shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5>Thông tin cá nhân</h5>
    </div>
    <div class="card-body">
        <p><strong>Họ tên:</strong> @Model.BenhNhan.HoTen</p>
        <p><strong>Ngày sinh:</strong> @Model.BenhNhan.NgaySinh.ToString("dd/MM/yyyy")</p>
        <p><strong>Giới tính:</strong> @Model.BenhNhan.GioiTinh</p>
        <p><strong>Số điện thoại:</strong> @Model.BenhNhan.SoDienThoai</p>
        <p><strong>Địa chỉ:</strong> @Model.BenhNhan.DiaChi</p>
        <p><strong>Dân tộc:</strong> @Model.BenhNhan.DanToc</p>
        <p><strong>Quốc tịch:</strong> @Model.BenhNhan.QuocTich</p>
        <p><strong>Đối tượng:</strong> @Model.BenhNhan.DoiTuong</p>
    </div>
</div>

<!-- Danh sách hồ sơ bệnh án -->
<h4 class="mb-3">Danh sách hồ sơ bệnh án</h4>

@if (Model.HoSoBenhAns.Count > 0)
{
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark text-center">
            <tr>
                <th>Mã hồ sơ</th>
                <th>Ngày tạo</th>
                <th>Bác sĩ lập</th>
                <th>Bác sĩ điều trị</th>
                <th>Trạng thái ra viện</th>
                <th>Chẩn đoán ra viện</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var hoSo in Model.HoSoBenhAns)
            {
                <tr>
                    <td class="text-center">@hoSo.MaHoSo</td>
                    <td class="text-center">@hoSo.NgayTao.ToString("dd/MM/yyyy")</td>
                    <td>@hoSo.BacSiLapBenhAn?.HoTen</td>
                    <td>@hoSo.BacSiDieuTri?.HoTen</td>
                    <td class="text-center">@hoSo.TrangThaiRaVien</td>
                    <td>@hoSo.ChanDoanRaVien</td>
                    <td class="text-center">
                        <a class="btn btn-sm btn-info" asp-controller="HoSoBenhAns" asp-action="Details" asp-route-id="@hoSo.MaHoSo">
                            <i class="fas fa-eye"></i> Xem chi tiết
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-danger">Bệnh nhân này chưa có hồ sơ bệnh án nào.</p>
}
